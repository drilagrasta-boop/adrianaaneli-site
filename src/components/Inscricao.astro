---
import { SITE } from '../site.config';
---
{SITE.followitAction && (
  <section class="inscricao">
    <h2>Receba os novos textos por e-mail</h2>
    <form action={SITE.followitAction} method="post" target="_blank">
      <label>Seu e-mail <input type="email" name="email" required /></label>
      <button type="submit">Inscrever-se</button>
    </form>
    <p class="meta">Um aviso a cada texto novo. Sem spam; cancele quando quiser.</p>
  </section>
)}
<style>
  .inscricao { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--cor-linha); text-align: center; }
  .inscricao h2 { margin-bottom: 1rem; }
  form { display: flex; flex-wrap: wrap; justify-content: center; align-items: end; gap: 0.75rem; }
  label { display: grid; gap: 0.3rem; text-align: left; }
  input { font: inherit; padding: 0.5rem; border: 1px solid var(--cor-linha); border-radius: 4px; background: #fff; min-width: 16rem; }
  button { font: inherit; cursor: pointer; padding: 0.5rem 1.25rem; border: 1px solid var(--cor-linha); border-radius: 4px; background: none; }
  button:hover { color: var(--cor-detalhe); border-color: var(--cor-detalhe); }
  .meta { margin-top: 0.75rem; }
</style>
